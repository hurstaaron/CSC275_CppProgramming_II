# =============================================================
# CSC275 — C++ Programming II
# .gitignore for Visual Studio / VS Code / C++ project
# =============================================================

# -------------------------------------------------------------
# Personal — never commit
# -------------------------------------------------------------

# Session notes, progress tracking, personal files
_Meta/

# -------------------------------------------------------------
# Visual Studio — local IDE state (machine-specific, not for repo)
# -------------------------------------------------------------

# VS local settings folder — different on every machine
.vs/

# Per-user project settings
*.user

# Solution user options
*.suo

# User OS cache
*.userosscache

# Document state (open tabs, scroll positions)
*.sln.docstates

# -------------------------------------------------------------
# Visual Studio — build output
# -------------------------------------------------------------

# Debug build output
[Dd]ebug/

# Release build output
[Rr]elease/

# 64-bit build artifacts
x64/

# 32-bit build artifacts
x86/

# ARM build artifacts
[Aa][Rr][Mm]/

# ARM64 build artifacts
[Aa][Rr][Mm]64/

# Binary output folder
[Bb]in/

# Object file staging folder
[Oo]bj/

# Build logs
[Ll]og/

# Build logs (alternate name)
[Ll]ogs/

# Build staging folder
bld/

# -------------------------------------------------------------
# Compiled object and intermediate files
# -------------------------------------------------------------

# Compiled object files
*.obj

# GCC/Clang object files
*.o

# Precompiled header (compiled)
*.pch

# GCC precompiled header
*.gch

# -------------------------------------------------------------
# Linker output (generated — not hand-authored)
# -------------------------------------------------------------

# Incremental linker state
*.ilk

# Linker map file
*.map

# Export file (generated alongside .lib)
*.exp

# Import library (generated, not static libs you write)
*.lib

# Dynamic link library output
*.dll

# Executable output
*.exe

# -------------------------------------------------------------
# Debug symbols
# -------------------------------------------------------------

# Program database — debug symbols
*.pdb

# -------------------------------------------------------------
# IntelliSense and browsing database
# -------------------------------------------------------------

# IntelliSense database
*.VC.db

# IntelliSense database (open)
*.VC.opendb

# IntelliSense precompiled headers
ipch/

# No compile browse (older VS)
*.ncb

# SQL Compact DB (older VS IntelliSense)
*.sdf

# Open SQL Compact DB
*.opensdf

# -------------------------------------------------------------
# NuGet packages
# -------------------------------------------------------------

# Downloaded NuGet packages — restore on build
packages/

# Package files
*.nupkg

# -------------------------------------------------------------
# CMake (if used alongside Visual Studio)
# -------------------------------------------------------------

# VS CMake settings (machine-specific)
CMakeSettings.json

# CMake cache
CMakeCache.txt

# CLion/CMake build directories
cmake-build-*/

# VS CMake output folder
out/

# -------------------------------------------------------------
# VS Code workspace settings
# -------------------------------------------------------------

# VS Code settings folder — contains launch.json and tasks.json
# Remove this line if you want to share your VS Code config with the team
.vscode/

# -------------------------------------------------------------
# Windows OS artifacts
# -------------------------------------------------------------

# Windows thumbnail cache
Thumbs.db

# Windows thumbnail cache (alternate)
ehthumbs.db

# Folder display settings
Desktop.ini

# Recycle bin artifacts
$RECYCLE.BIN/

# Windows shortcut files
*.lnk